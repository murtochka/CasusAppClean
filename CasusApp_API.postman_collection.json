{
  "info": {
    "name": "CasusApp API",
    "description": "Tour guide booking platform API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Health & Status",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/health",
              "host": ["{{base_url}}"],
              "path": ["health"]
            }
          }
        }
      ]
    },
    {
      "name": "Authentication",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"email\":\"user@example.com\",\"password\":\"SecurePass123!\",\"fullName\":\"John Doe\",\"role\":\"tourist\"}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/auth/register",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "auth", "register"]
            }
          }
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"email\":\"user@example.com\",\"password\":\"SecurePass123!\"}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/auth/login",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "auth", "login"]
            }
          }
        },
        {
          "name": "Get Current User",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{jwt_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/auth/me",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "auth", "me"]
            }
          }
        }
      ]
    },
    {
      "name": "Activities",
      "item": [
        {
          "name": "Get Categories",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/v1/categories",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "categories"]
            }
          }
        },
        {
          "name": "Get Activity by ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/v1/activities/:id",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "activities", ":id"]
            }
          }
        },
        {
          "name": "Search Activities",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/v1/activities/search?city=Zurich&difficulty=medium",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "activities", "search"],
              "query": [
                {
                  "key": "city",
                  "value": "Zurich"
                },
                {
                  "key": "difficulty",
                  "value": "medium"
                }
              ]
            }
          }
        },
        {
          "name": "Create Activity (Guide Only)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{jwt_token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"categoryId\":\"uuid\",\"title\":\"Mountain Hike\",\"description\":\"Scenic hike\",\"price\":45.00,\"maxParticipants\":8,\"durationMinutes\":120,\"difficulty\":\"medium\",\"city\":\"Zurich\",\"country\":\"Switzerland\"}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/activities",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "activities"]
            }
          }
        }
      ]
    },
    {
      "name": "Guides",
      "item": [
        {
          "name": "Get Guide Profile",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/v1/guides/:guideId",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "guides", ":guideId"]
            }
          }
        },
        {
          "name": "Create Guide Profile",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{jwt_token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"businessName\":\"Alpine Guides\",\"description\":\"Professional mountain guides\",\"licenseNumber\":\"LIC123456\"}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/guides/profile",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "guides", "profile"]
            }
          }
        }
      ]
    },
