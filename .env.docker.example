# CasusApp - Docker Environment Variables Template
# Copy this file to .env.docker and customize for your environment
# Usage: docker-compose --env-file .env.docker up

# ============================================
# Database Configuration (PostgreSQL + PostGIS)
# ============================================

# Database connection (container-to-container)
DATABASE_URL=postgresql://casusapp:casusapp_dev_password@postgres:5432/casusapp
DOCKER_DATABASE_URL=postgresql://casusapp:casusapp_dev_password@postgres:5432/casusapp

# Database connection (host-to-container - for migrations from host)
# DATABASE_URL=postgresql://casusapp:casusapp_dev_password@localhost:5433/casusapp

POSTGRES_DB=casusapp
POSTGRES_USER=casusapp
POSTGRES_PASSWORD=casusapp_dev_password

# ============================================
# Backend API Configuration
# ============================================

NODE_ENV=development
PORT=3000

# JWT Authentication
JWT_SECRET=dev_jwt_secret_change_in_production_min_32_chars
JWT_EXPIRES_IN=7d

# ============================================
# Stripe Payment Integration
# ============================================

STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# ============================================
# Cloudinary File Upload
# ============================================

CLOUDINARY_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# ============================================
# Redis Cache (Optional)
# ============================================

REDIS_ENABLED=false
REDIS_URL=redis://redis:6379

# ============================================
# Email Service (Nodemailer)
# ============================================

EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=your_email@gmail.com
EMAIL_PASSWORD=your_app_specific_password
EMAIL_FROM=noreply@casusapp.com

# ============================================
# Frontend Configuration
# ============================================

VITE_API_BASE_URL=http://localhost:3000/api/v1
VITE_APP_NAME=CasusApp
VITE_APP_VERSION=0.1.0

# ============================================
# Mobile App Configuration (Host-based)
# ============================================

# For Android Emulator (use host.docker.internal or 10.0.2.2)
EXPO_PUBLIC_API_BASE_URL=http://10.0.2.2:3000/api/v1

# For Android Physical Device over WiFi (use your machine's LAN IP)
# EXPO_PUBLIC_API_BASE_URL=http://192.168.1.XXX:3000/api/v1

EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key_here

# ============================================
# Development Settings
# ============================================

# Logging
LOG_LEVEL=debug
MORGAN_FORMAT=dev

# CORS
CORS_ORIGIN=http://localhost:5173,http://localhost:3000

# File Upload Limits
MAX_FILE_SIZE=10485760

# ============================================
# Notes
# ============================================

# 1. For container-to-container communication, use service names (postgres, backend, redis)
# 2. For host-to-container communication, use localhost or 127.0.0.1
# 3. For mobile emulator, use 10.0.2.2 (Android) or localhost (iOS Simulator)
# 4. For mobile physical device, use your machine's LAN IP address
# 5. Change all secrets and passwords in production
# 6. Never commit .env.docker to version control
