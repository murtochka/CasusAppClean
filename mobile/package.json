{
  "name": "casus-app-mobile",
  "version": "1.0.0",
  
  "scripts": {
    "clean": "rm -rf .expo node_modules/.cache",
    "start": "npm run clean && expo start",
    "start:no-clear": "expo start",
    "start:android:8082": "npm run dev:android:8082",
    "start:android:emulator:8082": "npm run dev:android:emulator:8082",
    "start:android:device:8082": "npm run dev:android:device:8082",
    "android": "npm run clean && expo start --android",
    "android:8082": "npm run dev:android:8082",
    "dev:android:8082": "npm run dev:android:emulator:8082",
    "dev:android:emulator:8082": "EXPO_PUBLIC_ANDROID_TARGET=emulator expo start --dev-client --android --host localhost --port 8082 --scheme casusapp --clear",
    "dev:android:device:8082": "EXPO_PUBLIC_ANDROID_TARGET=device expo start --dev-client --host lan --port 8082 --scheme casusapp --clear",
    "ios": "npm run clean && expo start --ios",
    "dev:android": "expo start --dev-client --android",
    "dev:ios": "expo start --dev-client --ios",
    "build:dev": "eas build --profile development_device --platform all",
    "build:dev:device": "eas build --profile development_device --platform all",
    "build:dev:emulator": "eas build --profile development_emulator --platform all",
    "web": "expo start --web",
    "test": "jest"
  },
  "dependencies": {
    "@expo-google-fonts/outfit": "^0.2.3",
    "@expo/config": "^55.0.8",
    "@expo/config-plugins": "^55.0.6",
    "@expo/metro": "^54.2.0",
    "@gorhom/bottom-sheet": "^4.6.0",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/datetimepicker": "8.4.4",
    "@react-native-community/netinfo": "11.4.1",
    "@react-navigation/bottom-tabs": "^7.4.0",
    "@react-navigation/native": "^7.1.8",
    "@react-navigation/native-stack": "^7.3.16",
    "@stripe/stripe-react-native": "0.50.3",
    "axios": "^1.6.2",
    "date-fns": "^2.30.0",
    "expo": "~54.0.0",
    "expo-calendar": "~15.0.8",
    "expo-constants": "~18.0.13",
    "expo-dev-client": "~6.0.20",
    "expo-font": "~14.0.11",
    "expo-haptics": "~15.0.8",
    "expo-image-picker": "~17.0.10",
    "expo-linear-gradient": "~15.0.8",
    "expo-linking": "~8.0.11",
    "expo-router": "~6.0.23",
    "expo-secure-store": "~15.0.8",
    "expo-sharing": "~14.0.8",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "fast-deep-equal": "^3.1.3",
    "getenv": "^2.0.0",
    "native-base": "^3.4.28",
    "normalize-css-color": "^1.0.2",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.80.3",
    "react-native-config": "^1.5.1",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-maps": "1.20.1",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-snap-carousel": "^3.9.1",
    "react-native-svg": "15.12.1",
    "react-native-toast-message": "^2.1.5",
    "react-native-web": "^0.21.2",
    "react-native-worklets": "0.5.1",
    "react-native-worklets-core": "^1.6.3",
    "styled-components": "^5.3.11",
    "styled-system": "^5.1.5",
    "undici": "^7.22.0",
    "wonka": "^6.3.5",
    "zod": "^3.22.4",
    "zustand": "^4.4.1"
  },
  "devDependencies": {
    "@expo/cli": "^54.0.23",
    "@testing-library/react-native": "^12.4.2",
    "@types/ms": "^2.1.0",
    "@types/react": "~19.1.10",
    "@typescript-eslint/parser": "^8.56.1",
    "babel-plugin-module-resolver": "^5.0.2",
    "eslint": "^9.39.1",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-react": "^7.37.5",
    "is-docker": "^4.0.0",
    "jest": "^29.7.0",
    "typescript": "~5.9.2"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
