{
  "cli": {
    "version": ">= 18.4.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "node": "20.18.1",
      "env": {
        "EXPO_PUBLIC_ANDROID_TARGET": "device"
      },
      "ios": {
        "simulator": true
      },
      "android": {
        "buildType": "apk"
      }
    },
    "development_device": {
      "developmentClient": true,
      "distribution": "internal",
      "node": "20.18.1",
      "env": {
        "EXPO_PUBLIC_ANDROID_TARGET": "device"
      },
      "ios": {
        "simulator": true
      },
      "android": {
        "buildType": "apk"
      }
    },
    "development_emulator": {
      "developmentClient": true,
      "distribution": "internal",
      "node": "20.18.1",
      "env": {
        "EXPO_PUBLIC_ANDROID_TARGET": "emulator",
        "EXPO_PUBLIC_API_BASE_URL": "http://10.0.2.2:3000/api/v1"
      },
      "ios": {
        "simulator": true
      },
      "android": {
        "buildType": "apk"
      }
    },
    "preview": {
      "distribution": "internal",
      "node": "20.18.1",
      "android": {
        "buildType": "apk"
      },
      "ios": {
        "simulator": true
      }
    },
    "preview2": {
      "distribution": "internal",
      "node": "20.18.1",
      "android": {
        "gradleCommand": ":app:assembleRelease"
      }
    },
    "preview3": {
      "distribution": "internal",
      "node": "20.18.1",
      "developmentClient": true
    },
    "production": {
      "autoIncrement": true,
      "node": "20.18.1",
      "android": {
        "buildType": "apk"
      },
      "ios": {
        "simulator": false
      }
    }
  },
  "submit": {
    "production": {}
  }
}
